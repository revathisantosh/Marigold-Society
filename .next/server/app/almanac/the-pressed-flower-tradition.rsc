0:["_yAPWz4cXx6D5XG9npipl",[[["",{"children":["almanac",{"children":[["slug","the-pressed-flower-tradition","d"],{"children":["__PAGE__?{\"slug\":\"the-pressed-flower-tradition\"}",{}]}]}]},"$undefined","$undefined",true],["",{"children":["almanac",{"children":[["slug","the-pressed-flower-tradition","d"],{"children":["__PAGE__",{},[["$L1",["$","div",null,{"className":"pt-28","children":[["$","header",null,{"className":"py-20 lg:py-28 bg-parchment-light","children":["$","div",null,{"className":"max-w-3xl mx-auto px-6 text-center","children":[["$","div",null,{"className":"ornament label text-marigold mb-8","children":"History"}],["$","h1",null,{"className":"font-display italic text-display-md text-maroon leading-tight mb-4","children":"The Memory of Flowers"}],["$","p",null,{"className":"font-body text-ink/60 text-xl italic leading-relaxed mb-8","children":"A short history of pressing, and why it has never gone out of fashion"}],["$","div",null,{"className":"flex items-center justify-center gap-4","children":[["$","p",null,{"className":"label text-ink/50","children":["By ","Thomas Alderidge"]}],["$","span",null,{"className":"text-marigold/50","children":"·"}],["$","p",null,{"className":"label text-ink/50","children":"The Almanac No. 5 — Summer"}],["$","span",null,{"className":"text-marigold/50","children":"·"}],["$","p",null,{"className":"label text-ink/50","children":[6," min read"]}]]}]]}]}],["$","article",null,{"className":"py-16 lg:py-24 max-w-7xl mx-auto px-6 lg:px-12","children":["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-12 gap-16","children":[["$","aside",null,{"className":"hidden lg:flex lg:col-span-2 justify-end pt-8","children":["$","$L2",null,{"variant":"sprig-tall","className":"w-10 h-48 text-vine/50"}]}],["$","div",null,{"className":"lg:col-span-7","children":[["$","div",null,{"className":"prose-custom space-y-8 font-body text-ink/85 text-xl leading-relaxed","children":[["$","p","0",{"children":[["$","span",null,{"className":"float-left font-display italic text-7xl text-maroon leading-none mr-3 mt-1","children":"T"}],"he Victorians pressed flowers with a fervor that we might now call obsessive. In the language of flowers — floriography, to give it its proper name — a single sprig of lavender tucked inside a letter could say what propriety forbade speaking aloud. Pansy for thoughts. Rosemary for remembrance. Red tulip for a declaration of love so bold it required the cover of botany to survive."]}],["$","p","1",{"className":"font-body text-ink/80 text-xl leading-relaxed","children":"But flower-pressing long predates the Victorians. Herbalists pressed specimens for identification and documentation from the earliest days of botanical study — Luca Ghini, who taught at Bologna in the 1530s, is generally credited with inventing the practice. His students carried it across Europe, and within a generation, the herbarium had become the essential tool of the natural philosopher."}],["$","blockquote","2",{"className":"border-l-4 border-marigold pl-8 my-12 font-display italic text-2xl text-maroon leading-relaxed","children":"Every pressed flower is a kind of stopped clock — a moment of bloom preserved against the certainty of decay."}],["$","p","3",{"className":"font-body text-ink/80 text-xl leading-relaxed","children":"What is it that makes the pressed flower such a persistent human impulse? I have thought about this for years, standing over my great-aunt's herbarium in Woodstock, turning the tissue-thin pages with their crumbling specimens still fragrant after eighty years. I think it is the same impulse that makes us photograph things we love: the desire to arrest time, to say 'this existed, and I was here with it.'"}],["$","h2","4",{"className":"font-display italic text-3xl text-maroon mt-12 mb-2","children":"Technique and Time"}],["$","p","5",{"className":"font-body text-ink/80 text-xl leading-relaxed","children":"The technique itself has changed little. You need a press (two boards, some bolts, absorbent paper), or in a pinch, a heavy book with sheets of blotting paper. Flowers should be harvested at mid-morning after dew has dried but before afternoon heat sets in. They should be slightly less than fully open — pressing captures a moment, and a bloom just before its peak preserves a quality of anticipation."}],["$","p","6",{"className":"font-body text-ink/80 text-xl leading-relaxed","children":"The waiting is the hardest part. Three weeks minimum for most specimens, longer for succulent flowers or those with a high moisture content. The temptation to check is almost unbearable. Resist it: any disturbance during the drying process risks smearing colors or misaligning petals, and the patience will be repaid by specimens that hold their color and form for decades."}],["$","p","7",{"className":"font-body text-ink/80 text-xl leading-relaxed","children":"Our pressed-flower kits include the papers and pressing boards, but also something equally important: an archival journal in which to place the pressed specimens alongside notes. Date, location, plant name if known, any observations about the growing conditions or the particular quality of light that day. This context is what elevates a pressed flower from a curiosity to a document — a record not only of the flower but of the life it was embedded in."}]]}],["$","div",null,{"className":"mt-16 pt-8 border-t border-marigold/20","children":["$","div",null,{"className":"flex items-start gap-4","children":[["$","div",null,{"className":"w-12 h-12 rounded-full bg-marigold/20 flex items-center justify-center shrink-0","children":["$","span",null,{"className":"font-display italic text-xl text-maroon","children":"T"}]}],["$","div",null,{"children":[["$","p",null,{"className":"font-display italic text-lg text-ink mb-1","children":"Thomas Alderidge"}],["$","p",null,{"className":"font-body text-ink/60 text-base leading-relaxed","children":"Thomas Alderidge is The Almanac's contributing editor for material culture. He lives in Woodstock, Vermont, where he maintains a Victorian-era herbarium begun by his great-aunt."}]]}]]}]}]]}],["$","aside",null,{"className":"lg:col-span-3","children":["$","div",null,{"className":"sticky top-28 space-y-8","children":[["$","div",null,{"className":"border border-marigold/25 p-6","children":[["$","p",null,{"className":"label text-marigold mb-3","children":"This article appeared in"}],["$","p",null,{"className":"font-display italic text-lg text-ink mb-1","children":"The Almanac No. 5 — Summer"}],["$","p",null,{"className":"label text-2xs text-ink/40 mb-4","children":"June 2024"}],["$","$L3",null,{"href":"/membership","className":"block text-center bg-maroon text-white py-3 label hover:bg-maroon-deep transition-colors","children":"Subscribe to The Almanac"}]]}],["$","div",null,{"children":[["$","p",null,{"className":"label text-ink/40 mb-3","children":"Topics"}],["$","div",null,{"className":"flex flex-wrap gap-2","children":[["$","span","pressed flowers",{"className":"label text-2xs border border-marigold/25 text-ink/50 px-2 py-1","children":"pressed flowers"}],["$","span","history",{"className":"label text-2xs border border-marigold/25 text-ink/50 px-2 py-1","children":"history"}],["$","span","craft",{"className":"label text-2xs border border-marigold/25 text-ink/50 px-2 py-1","children":"craft"}],["$","span","victoriana",{"className":"label text-2xs border border-marigold/25 text-ink/50 px-2 py-1","children":"victoriana"}]]}]]}]]}]}]]}]}],false]}]],null],null]},["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children","almanac","children","$5","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L6",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","notFoundStyles":"$undefined","styles":null}],null]},["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children","almanac","children"],"error":"$undefined","errorStyles":"$undefined","errorScript