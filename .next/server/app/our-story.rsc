0:["_yAPWz4cXx6D5XG9npipl",[[["",{"children":["our-story",{"children":["__PAGE__",{}]}]},"$undefined","$undefined",true],["",{"children":["our-story",{"children":["__PAGE__",{},[["$L1",["$","div",null,{"className":"pt-28","children":[["$","section",null,{"className":"py-20 lg:py-28 max-w-7xl mx-auto px-6 lg:px-12","children":["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-12 gap-12 items-end","children":[["$","div",null,{"className":"lg:col-span-7","children":[["$","div",null,{"className":"ornament label text-marigold mb-8","children":"Our Story"}],["$","$L2",null,{"text":"What began as a seed swap became a small institution.","tag":"h1","className":"font-display italic text-display-lg text-maroon leading-none"}]]}],["$","div",null,{"className":"lg:col-span-4 lg:col-start-9","children":["$","p",null,{"className":"font-body text-ink/70 text-xl leading-relaxed","children":"Strafford, Vermont. The farm sits on forty acres of old dairy pasture, most of it still grass, with a seed garden, a cutting garden, and a barn that Oliver converted into a seed-drying and printing operation in 2022."}]}]]}]}],["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12","children":["$","hr",null,{"className":"section-rule"}]}],["$","section",null,{"className":"py-24 lg:py-36 max-w-7xl mx-auto px-6 lg:px-12","children":["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-12 gap-16","children":[["$","div",null,{"className":"lg:col-span-3 flex justify-center","children":["$","$L3",null,{"variant":"vine","className":"w-16 h-80 text-vine"}]}],["$","div",null,{"className":"lg:col-span-8 lg:col-start-4","children":["$","div",null,{"className":"space-y-8 font-body text-ink/80 text-xl leading-relaxed","children":[["$","p",null,{"children":"The church basement smelled of old hymnals and someone's good idea about coffee cake. It was January 2020, and Estelle had set up a folding table with perhaps sixty packets of seeds laid out in alphabetical order — a catalog she had been assembling, without any particular plan, for six years of seed swaps and correspondence with growers across the country and overseas."}],["$","p",null,{"children":"She had expected perhaps twenty people. Thirty-seven came."}],["$","p",null,{"children":["What she noticed, moving around the room, was not just enthusiasm for the seeds themselves — though there was that — but a kind of recognition. People picked up a packet and told a story. ",["$","em",null,{"children":"My grandmother grew this in New Hampshire."}]," ",["$","em",null,{"children":"I found this at a swap in Quebec in 1998 and I've been growing it ever since."}]," ",["$","em",null,{"children":"I have no idea where I got this or what it is but it's the best tomato I've ever eaten and I need someone else to know about it."}]]}],["$","p",null,{"className":"text-2xl font-display italic text-maroon","children":"The Marigold Society began, in that moment, as a room full of people who understood that certain things are worth keeping."}],["$","p",null,{"children":"We have tried to build the rest of it — the seed library, the journal, the farm, the membership, the Greenhouse — around that understanding. The seeds are the center of gravity. Everything else orbits them."}]]}]}]]}]}],["$","section",null,{"className":"py-24 bg-maroon text-white","children":["$","div",null,{"className":"max-w-7xl mx-auto px-6 lg:px-12","children":[["$","div",null,{"className":"ornament label text-marigold mb-16","children":"The Founders"}],["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-2 gap-0.5","children":[["$","div","Estelle Marchand",{"className":"bg-maroon border border-white/10 p-12","children":[["$","div",null,{"className":"mb-8","children":[["$","div",null,{"className":"w-16 h-16 rounded-full bg-marigold/20 flex items-center justify-center mb-6","children":["$","span",null,{"className":"font-display italic text-2xl text-marigold","children":"E"}]}],["$","h3",null,{"className":"font-display italic text-3xl text-white mb-1","children":"Estelle Marchand"}],["$","p",null,{"className":"label text-marigold","children":"Co-Founder & Seed Curator"}]]}],["$","p",null,{"className":"font-body text-white/75 text-lg leading-relaxed mb-6","children":"Estelle studied botany at Middlebury College and spent three years apprenticing under the plantswomen Helen Muir before returning to Vermont to start a seed garden. She is responsible for the acquisition, cultivation, and documentation of every variety in the Marigold Society library. She writes in The Almanac under her own name and, occasionally, under the pseudonym E.M. Callow."}],["$","p",null,{"className":"font-body italic text-white/50 text-base border-l-2 border-marigold/40 pl-4","children":"Tends 40 varieties of cut flower in the south garden, maintains correspondence with seed custodians on three continents, and makes an unacceptable amount of calendula salve each autumn."}]]}],["$","div","Oliver Marchand",{"className":"bg-maroon border border-white/10 p-12","children":[["$","div",null,{"className":"mb-8","children":[["$","div",null,{"className":"w-16 h-16 rounded-full bg-marigold/20 flex items-center justify-center mb-6","children":["$","span",null,{"className":"font-display italic text-2xl text-marigold","children":"O"}]}],["$","h3",null,{"className":"font-display italic text-3xl text-white mb-1","children":"Oliver Marchand"}],["$","p",null,{"className":"label text-marigold","children":"Co-Founder & Editor"}]]}],["$","p",null,{"className":"font-body text-white/75 text-lg leading-relaxed mb-6","children":"Oliver trained as a furniture-maker at the North Bennet Street School in Boston before a series of events — a seed swap, a woman with eight hundred packets of seeds, a van — changed the direction of his life entirely. He is responsible for the physical production of The Almanac, the design of the seed packaging, and the farm buildings."}],["$","p",null,{"className":"font-body italic text-white/50 text-base border-l-2 border-marigold/40 pl-4","children":"Grows the dry beans and grain crops, maintains the seed-drying barn, typeset the first four issues of The Almanac by hand, and still occasionally makes furniture."}]]}]]}]]}]}],["$","section",null,{"className":"py-24 lg:py-36 max-w-7xl mx-auto px-6 lg:px-12","children":[["$","div",null,{"className":"ornament label text-marigold mb-16","children":"A Brief History"}],["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-2 gap-0","children":[["$","div","2019",{"className":"border-l-2 border-marigold pl-8 pb-12","children":[["$","p",null,{"className":"font-display italic text-4xl text-marigold mb-3","children":"2019"}],["$","p",null,{"className":"font-body text-ink/75 text-lg leading-relaxed","children":"Estelle begins documenting the seed library she has assembled over six years of swaps and correspondence."}]]}],["$","div","2020",{"className":"border-l-2 border-maroon/40 pl-8 pb-12","children":[["$","p",null,{"className":"font-display italic text-4xl text-marigold mb-3","children":"2020"}],["$","p",null,{"className":"font-body text-ink/75 text-lg leading-relaxed","children":"First winter seed swap in a church basement in Burlington. Thirty-seven people attend. More than expected."}]]}],["$","div","2021",{"className":"border-l-2 border-marigold pl-8 pb-12","children":[["$","p",null,{"className":"font-display italic text-4xl text-marigold mb-3","children":"2021"}],["$","p",null,{"className":"font-body text-ink/75 text-lg leading-relaxed","children":"The Marigold Society is incorporated. The first Almanac is printed on a Risograph in Oliver's workshop. Issue one sells out in eleven days."}]]}],["$","div","2022",{"className":"border-l-2 border-maroon/40 pl-8 pb-12","children":[["$","p",null,{"className":"font-display italic text-4xl text-marigold mb-3","children":"2022"}],["$","p",null,{"className":"font-body text-ink/75 text-lg leading-relaxed","children":"We move to the farm in Strafford. The seed garden is planted for the first time as a proper growing enterprise rather than a private obsession."}]]}],["$","div","2023",{"className":"border-l-2 border-marigold pl-8 pb-12","children":[["$","p",null,{"className":"font-display italic text-4xl text-marigold mb-3","children":"2023"}],["$","p",null,{"className":"font-body text-ink/75 text-lg leading-relaxed","children":"The Cultivator subscription tier is introduced. Membership reaches 800. We hire our first employee, Sam Bellows, who manages the seed library and is a better organizer than either of us."}]]}],["$","div","2024",{"className":"border-l-2 border-maroon/40 pl-8 pb-12","children":[["$","p",null,{"className":"font-display italic text-4xl text-marigold mb-3","children":"2024"}],["$","p",null,{"className":"font-body text-ink/75 text-lg leading-relaxed","children":"The Greenhouse opens — our members' forum, which turns out to be where the most interesting conversations happen. The pressed-flower kit is introduced in response to many, many requests."}]]}],["$","div","2025",{"className":"border-l-2 border-marigold pl-8 pb-12","children":[["$","p",null,{"className":"font-display italic text-4xl text-marigold mb-3","children":"2025"}],["$","p",null,{"className":"font-body text-ink/75 text-lg leading-relaxed","children":"1,400 members. The Almanac reaches its ninth issue. We are, somehow, still surprised by how many people care about these things."}]]}]]}]]}],["$","section",null,{"className":"py-24 bg-maroon text-white relative overflow-hidden min-h-0","children":[["$","div",null,{"className":"absolute inset-0 pointer-events-none overflow-hidden min-h-0 min-w-0","children":[["$","$L4",null,{"src":"/images/Seed%20Garden.png","alt":"","fill":true,"sizes":"100vw","className":"object-cover object-top opacity-25"}],["$","div",null,{"className":"absolute inset-0 bg-maroon/85","aria-hidden":true}]]}],["$","div",null,{"className":"absolute inset-0 opacity-5 pointer-events-none flex items-center justify-center z-[1] overflow-hidden","children":["$","$L3",null,{"variant":"marigold","className":"w-[min(90vw,28rem)] h-[min(90vw,28rem)] shrink-0 text-white max-w-full"}]}],["$","div",null,{"className":"relative z-10 max-w-3xl mx-auto px-6 text-center","children":[["$","div",null,{"className":"ornament label text-white mb-8","children":"Come and See"}],["$","h2",null,{"className":"font-display italic text-display-md text-white leading-tight mb-8","children":"The farm is open from May through October."}],["$","p",null,{"className":"font-body text-white/75 text-xl leading-relaxed mb-12","children":"We welcome visitors during the growing season, by appointment or on our open days (announced in The Almanac and to members first). The seed garden is at its most extraordinary in late July, when the hollyhocks are eight feet tall and the marigolds have gone slightly mad."}],["$","div",null,{"className":"flex flex-col sm:flex-row items-center justify-center gap-4","children":["$","a",null,{"href":"/visit","className":"inline-block bg-parchment text-ink px-10 py-4 font-display italic text-xl hover:bg-marigold transition-colors duration-300","children":"Plan a visit"}]}]]}]]}],["$","section",null,{"className":"py-24 lg:py-36 max-w-7xl mx-auto px-6 lg:px-12","children":[["$","div",null,{"className":"grid grid-cols-1 lg:grid-cols-3 gap-12","children":[["$","div","On seeds",{"className":"border-t-2 border-marigold pt-8","children":[["$","h3",null,{"className":"font-display italic text-2xl text-maroon mb-4","children":"On seeds"}],["$","p",null,{"className":"font-body text-ink/70 leading-relaxed","children":"We do not own the varieties in our library. We are stewards. Every seed we sell comes with an implicit request: grow it, save it, share it. The library exists only as long as people are willing to participate in its continuation."}]]}],["$","div","On the Almanac",{"className":"border-t-2 border-marigold pt-8","children":[["$","h3",null,{"className":"font-display italic text-2xl text-maroon mb-4","children":"On the Almanac"}],["$","p",null,{"className":"font-body text-ink/70 leading-relaxed","children":"We make the Almanac on paper because paper is permanent. We write slowly and edit carefully because we believe the things worth printing are worth taking time over. We have never published a piece we don't believe in."}]]}],["$","div","On community",{"className":"border-t-2 border-marigold pt-8","children":[["$","h3",null,{"className":"font-display italic text-2xl text-maroon mb-4","children":"On community"}],["$","p",null,{"className":"font-body text-ink/70 leading-relaxed","children":"The Marigold Society is a membership because it is, genuinely, a society — a group of people with shared interests and shared obligations to each other. We try to run it like one."}]]}]]}],["$","div",null,{"className":"mt-24 flex justify-center","children":["$","svg",null,{"className":"w-80 h-16 text-marigold/30","viewBox":"0 0 320 80","fill":"none","stroke":"currentColor","strokeWidth":"1","xmlns":"http://www.w3.org/2000/svg","children":[["$","line",null,{"x1":"160","y1":"75","x2":"160","y2":"10"}],["$","path",null,{"d":"M160 50 Q130 40 115 25"}],["$","path",null,{"d":"M115 25 Q105 15 120 10 Q125 20 115 25","fill":"currentColor","opacity":"0.3"}],["$","path",null,{"d":"M137 38 Q127 28 138 20 Q143 30 137 38","fill":"currentColor","opacity":"0.3"}],["$","path",null,{"d":"M160 50 Q190 40 205 25"}],["$","path",null,{"d":"M205 25 Q215 15 200 10 Q196 20 205 25","fill":"currentColor","opacity":"0.3"}],["$","path",null,{"d":"M183 38 Q193 28 182 20 Q177 30 183 38","fill":"currentColor","opacity":"0.3"}],[["$","ellipse","0",{"cx":168,"cy":10,"rx":"3.5","ry":"2","fill":"currentColor","opacity":"0.6","transform":"rotate(0 168 10)"}],["$","ellipse","1",{"cx":164,"cy":16.928203230275507,"rx":"3.5","ry":"2","fill":"currentColor","opacity":"0.6","transform":"rotate(60 164 16.928203230275507)"}],["$","ellipse","2",{"cx":156,"cy":16.92820323027551,"rx":"3.5","ry":"2","fill":"currentColor","opacity":"0.6","transform":"rotate(120 156 16.928